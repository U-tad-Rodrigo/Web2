# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SOCKET_CORS_ORIGIN=*

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bildyapp?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=7

# ── Cloudinary (subida de firmas y PDFs) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_email@gmail.com
MAIL_PASS=tu_app_password
MAIL_FROM=BildyApp <tu_email@gmail.com>

# ── Slack Webhook (logging errores 5XX) ───────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
