{
  "name": "biblioteca-api-deploy",
  "version": "1.0.0",
  "description": "API de Biblioteca Digital preparada para producción — T11 Deploy & DevOps",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node src/index.js",
    "test": "node --test tests/",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pm2": "^5.4.3"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1"
  }
}
