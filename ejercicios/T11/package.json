{
  "name": "biblioteca-api-deploy",
  "version": "1.0.0",
  "description": "API de Biblioteca Digital preparada para producción — T11 Deploy & DevOps",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node_modules/.bin/prisma migrate deploy && node_modules/.bin/pm2-runtime ecosystem.config.cjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "db:migrate": "node_modules/.bin/prisma migrate deploy",
    "db:generate": "node_modules/.bin/prisma generate",
    "db:studio": "node_modules/.bin/prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "pino": "^9.6.0",
    "pm2": "^5.4.3",
    "prisma": "^6.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0"
  }
}
