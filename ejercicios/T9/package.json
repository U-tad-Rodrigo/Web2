{
  "name": "biblioteca-api",
  "version": "1.0.0",
  "description": "API de Biblioteca Digital con Express, Supabase y Prisma",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node --env-file=.env src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:seed": "node --env-file=.env prisma/seed.js",
    "db:generate": "npx prisma generate"
  },
  "keywords": ["express", "api", "supabase", "postgresql", "prisma"],
  "author": "Rodrigo",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "prisma": "^6.2.1"
  }
}

