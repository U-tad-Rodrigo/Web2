{
  "name": "podcasthub-api",
  "version": "1.0.0",
  "description": "PodcastHub API - Ejercicio T8",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=.env src/index.js",
    "start": "node --env-file-if-exists=.env src/index.js",
